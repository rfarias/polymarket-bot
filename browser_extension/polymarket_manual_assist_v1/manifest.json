{
  "manifest_version": 3,
  "name": "Polymarket Manual Assist V1",
  "version": "1.0.0",
  "description": "In-page manual assist overlay for Polymarket current/almost-resolved decisions.",
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ]
}
