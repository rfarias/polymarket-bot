# ===== Broker credentials =====
# Fill these with your real values.
POLY_MODE=real
POLY_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137
POLY_SIGNATURE_TYPE=1
POLY_PRIVATE_KEY=
POLY_FUNDER=
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ===== Guarded runner (safe defaults) =====
POLY_GUARDED_ENABLED=true
POLY_GUARDED_SHADOW_ONLY=false
POLY_GUARDED_REAL_POSTS_ENABLED=true
POLY_GUARDED_MAX_ACTIVE_PLANS=1
POLY_GUARDED_ALLOW_NEXT_2=false
POLY_GUARDED_MIN_SHARES=5
POLY_GUARDED_DEADLINE_TRIGGER_SECS=330
POLY_GUARDED_REQUIRE_SIGNAL=armed
POLY_GUARDED_RUN_SECONDS=900

# ===== Scalp reversal mode v1 (separate from hedge mode) =====
POLY_SCALP_ENABLED=false
POLY_SCALP_ALLOWED_SLOTS=next_1
POLY_SCALP_RUN_SECONDS=600
POLY_SCALP_LOOP_SLEEP_SECS=2
POLY_SCALP_QTY=1
POLY_SCALP_STRETCH_PRICE_MAX=0.36
POLY_SCALP_MAX_SPREAD=0.03
POLY_SCALP_MIN_DEPTH_TOP3=8
POLY_SCALP_TARGET_TICKS=1
POLY_SCALP_STOP_TICKS=2
POLY_SCALP_ENTRY_TIMEOUT_SECS=12
POLY_SCALP_POSITION_TIMEOUT_SECS=20
POLY_SCALP_MIN_SECS_TO_END=45
