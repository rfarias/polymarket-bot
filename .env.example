# ===== Broker credentials =====
# Fill these with your real values.
POLY_MODE=real
POLY_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137
POLY_SIGNATURE_TYPE=1
POLY_PRIVATE_KEY=
POLY_FUNDER=
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ===== Guarded runner (safe defaults) =====
POLY_GUARDED_ENABLED=true
POLY_GUARDED_SHADOW_ONLY=false
POLY_GUARDED_REAL_POSTS_ENABLED=true
POLY_GUARDED_MAX_ACTIVE_PLANS=1
POLY_GUARDED_ALLOW_NEXT_2=false
POLY_GUARDED_MIN_SHARES=5
POLY_GUARDED_DEADLINE_TRIGGER_SECS=330
POLY_GUARDED_REQUIRE_SIGNAL=armed
POLY_GUARDED_RUN_SECONDS=900

# ===== Scalp reversal runner (disabled by default) =====
POLY_SCALP_ENABLED=false
POLY_SCALP_RUN_SECONDS=300
POLY_SCALP_LOOP_SLEEP_SECS=2
POLY_SCALP_ALLOWED_SLOTS=current
POLY_SCALP_QTY=1
POLY_SCALP_STRETCH_PRICE_MAX=0.36
POLY_SCALP_MAX_SPREAD=0.03
POLY_SCALP_MIN_DEPTH_TOP3=8
POLY_SCALP_TARGET_TICKS=1
POLY_SCALP_STOP_TICKS=2
POLY_SCALP_ENTRY_TIMEOUT_SECS=12
POLY_SCALP_POSITION_TIMEOUT_SECS=20
POLY_SCALP_MIN_SECS_TO_END=45

# ===== Multi-setup current legs =====
POLY_MULTI_RUN_SECONDS=900
POLY_MULTI_NEXT1_CANCEL_SECS=360
POLY_CURRENT_SCALP_SHADOW_ONLY=true
POLY_CURRENT_ALMOST_RESOLVED_SHADOW_ONLY=true

# ===== Next1 scalp real runner =====
POLY_NEXT1_SCALP_REAL_ENABLED=false
POLY_NEXT1_SCALP_AGGRESSIVE_QTY=6
POLY_NEXT1_SCALP_PASSIVE_QTY=0
POLY_NEXT1_SCALP_ENTRY_TIMEOUT_SECS=25
POLY_NEXT1_SCALP_ENTRY_REPRICE_SECS=1
POLY_NEXT1_SCALP_EXIT_REPOST_SECS=6
POLY_NEXT1_SCALP_POLL_SECS=0.5
POLY_NEXT1_SCALP_RUN_SECONDS=1200

# ===== Current scalp real runner =====
POLY_CURRENT_SCALP_REAL_ENABLED=false
POLY_CURRENT_SCALP_QTY=1
POLY_CURRENT_SCALP_ENTRY_TIMEOUT_SECS=12
POLY_CURRENT_SCALP_POSITION_TIMEOUT_SECS=20
POLY_CURRENT_SCALP_POLL_SECS=1.0
POLY_CURRENT_SCALP_RUN_SECONDS=1800

# ===== Current almost-resolved real runner =====
POLY_CURRENT_ALMOST_RESOLVED_REAL_ENABLED=false
POLY_CURRENT_ALMOST_RESOLVED_QTY=5
POLY_CURRENT_ALMOST_RESOLVED_ENTRY_TIMEOUT_SECS=2
POLY_CURRENT_ALMOST_RESOLVED_EXIT_REPOST_SECS=1
POLY_CURRENT_ALMOST_RESOLVED_FLATTEN_DEADLINE_SECS=2
POLY_CURRENT_ALMOST_RESOLVED_MIN_LIMIT_EXIT_QTY=5
POLY_CURRENT_ALMOST_RESOLVED_POLL_SECS=0.5
POLY_CURRENT_ALMOST_RESOLVED_RUN_SECONDS=1800
